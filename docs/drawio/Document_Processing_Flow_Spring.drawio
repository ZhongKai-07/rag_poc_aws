        <mxCell id="record-bg" value="&lt;b&gt;ProcessingRecordRepository&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:9px;color:#6D28D9'&gt;@Repository&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style='font-size:9px;font-family:Courier New'&gt;recordRepo.save(&lt;br/&gt;    ProcessingRecord.of(file.getName(), indexName)&lt;br/&gt;);&lt;/font&gt;&lt;br/&gt;&lt;br/&gt;&lt;font style='font-size:9px;color:#6B7280'&gt;// 写入 processed_files.txt&lt;br/&gt;// { fileName, indexName, processedAt }&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAF5FF;strokeColor=#7C3AED;strokeWidth=2;fontSize=10;fontColor=#4C1D95;align=left;spacingLeft=16;verticalAlign=top;spacingTop=10;"
