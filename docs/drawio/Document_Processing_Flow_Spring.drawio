        <!-- DocumentIndexRepository -->
        <mxCell id="repo" value="&lt;b&gt;DocumentIndexRepository&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:9px;color:#1E40AF'&gt;@Repository&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=10;fontColor=#1E3A8A;verticalAlign=top;spacingTop=8;"
          vertex="1" parent="1">
          <mxGeometry x="115" y="986" width="460" height="168" as="geometry" />
        </mxCell>

        <mxCell id="repo-code" value="String indexName = DigestUtils.md5Hex(file.getName()).substring(0, 8);&lt;br/&gt;&lt;br/&gt;List&lt;IndexDocument&gt; docs = IntStream&lt;br/&gt;    .range(0, chunks.size()).mapToObj(i -&gt;&lt;br/&gt;        IndexDocument.builder()&lt;br/&gt;            .indexName(indexName)&lt;br/&gt;            .paragraph(chunks.get(i).getText())&lt;br/&gt;            .sentenceVector(vectors.get(i)) // float[1536]&lt;br/&gt;            .sentence(chunks.get(i).getSummary())&lt;br/&gt;            .source(file.getName())&lt;br/&gt;            .build()&lt;br/&gt;    ).toList();&lt;br/&gt;repository.bulkIndex(docs);"
          style="text;html=1;strokeColor=#93C5FD;fillColor=#F0F9FF;fontSize=9;fontColor=#1E3A8A;align=left;spacingLeft=8;rounded=1;arcSize=5;fontFamily=Courier New;"
          vertex="1" parent="1">
          <mxGeometry x="125" y="1023" width="440" height="120" as="geometry" />
        </mxCell>

        <!-- OpenSearch Index output -->
        <mxCell id="os-out" value="&lt;b&gt;OpenSearch Index&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:9px'&gt;ap-east-1 (Hong Kong)&lt;br/&gt;Index: {indexName}&lt;br/&gt;&lt;br/&gt;sentence_vector: float[1536]&lt;br/&gt;paragraph  |  sentence  |  source&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE9FE;strokeColor=#7C3AED;strokeWidth=2;fontSize=10;fontColor=#4C1D95;"
          vertex="1" parent="1">
          <mxGeometry x="660" y="986" width="330" height="168" as="geometry" />
        </mxCell>

        <!-- arrow repo → opensearch -->
        <mxCell id="arr-repo-os" value="&lt;b&gt;bulkIndex()&lt;/b&gt;"
          style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#7C3AED;strokeWidth=2;endArrow=block;endFill=1;fontColor=#4C1D95;fontSize=9;fontStyle=1;"
          edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
