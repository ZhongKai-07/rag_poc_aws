          vertex="1" parent="1">
          <mxGeometry x="85" y="696" width="160" height="26" as="geometry" />
        </mxCell>

        <!-- EmbeddingService -->
        <mxCell id="emb-svc" value="&lt;b&gt;EmbeddingService&lt;/b&gt;&lt;br/&gt;&lt;font style='font-size:9px;color:#1E40AF'&gt;@Service  ·  AWS Bedrock Titan&lt;/font&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=10;fontColor=#1E3A8A;verticalAlign=top;spacingTop=8;"
          vertex="1" parent="1">
          <mxGeometry x="115" y="738" width="460" height="138" as="geometry" />
        </mxCell>

        <mxCell id="emb-code" value="List&lt;float[]&gt; vectors =&lt;br/&gt;    embeddingService.embedDocuments(&lt;br/&gt;        chunks.stream()&lt;br/&gt;              .map(TextChunk::getText)&lt;br/&gt;              .toList()&lt;br/&gt;    );&lt;br/&gt;&lt;font color=&apos;#6B7280&apos;&gt;// Model: amazon.titan-embed-text-v1&lt;br/&gt;// Dim: 1536  ·  Region: ap-northeast-1&lt;/font&gt;"
          style="text;html=1;strokeColor=#93C5FD;fillColor=#F0F9FF;fontSize=9;fontColor=#1E3A8A;align=left;spacingLeft=8;rounded=1;arcSize=5;fontFamily=Courier New;"
          vertex="1" parent="1">
          <mxGeometry x="125" y="775" width="440" height="90" as="geometry" />
        </mxCell>

