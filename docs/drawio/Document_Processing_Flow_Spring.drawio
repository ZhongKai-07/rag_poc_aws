          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#3B82F6;strokeWidth=1.5;fontSize=10;fontColor=#1E3A8A;verticalAlign=top;spacingTop=8;"
          vertex="1" parent="1">
          <mxGeometry x="115" y="510" width="460" height="118" as="geometry" />
        </mxCell>

        <mxCell id="splitter-code" value="List&lt;TextChunk&gt; chunks = splitter.split(&lt;br/&gt;    doc,&lt;br/&gt;    Map.of(&apos;#&apos;,&apos;h1&apos;, &apos;##&apos;,&apos;h2&apos;, &apos;###&apos;,&apos;h3&apos;),&lt;br/&gt;    MIN_CHARS_PER_CHUNK  // 100&lt;br/&gt;);"
          style="text;html=1;strokeColor=#93C5FD;fillColor=#F0F9FF;fontSize=9;fontColor=#1E3A8A;align=left;spacingLeft=8;rounded=1;arcSize=5;fontFamily=Courier New;"
